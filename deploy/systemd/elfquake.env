# Optional environment file for /etc/default/elfquake.
#
# The packaged unit reads this file after built-in defaults, so values here
# override the service defaults after installation.

ELFQUAKE_VLF_INTERVAL_SECONDS=1800
ELFQUAKE_LOOKBACK_HOURS=24
ELFQUAKE_HORIZON_DAYS=7
ELFQUAKE_TARGET_MAGNITUDE_MIN=3.0
ELFQUAKE_MIN_ANCHOR_GAP_SECONDS=60
